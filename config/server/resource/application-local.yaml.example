ikaros:
  show-theme: true
  security:
    # 30 day for local dev token expire
    jwt-expiration-time: 18144000000
    initializer:
      master-username: tomoki
      master-password: tomoki
  indices:
    initializer:
      enabled: true

  cache:
    enable: false
    type: memory
    redis:
      host: localhost
      port: 6379
      password: openredis
      expiration-time: 259200000
      timeout: 10000


  plugin:
    runtime-mode: development
    auto-start-plugin: true
    fixed-plugin-path:
    #  - C:\Users\chivehao\GitRepos\ikaros-dev\plugin-bgmtv
    #  - C:\Users\chivehao\GitRepos\ikaros-dev\plugin-pan115
    #  - C:\Users\chivehao\GitRepos\ikaros-dev\plugin-openlist
    #      - C:\Users\chivehao\GitRepos\ikaros-dev\plugin-mikan
    #      - C:\Users\chivehao\GitRepos\ikaros-dev\plugin-starter
    #      - C:\Users\chivehao\GitRepos\ikaros-dev\plugin-local-files-import
    #      - C:\Develop\GitRepos\ikaros-dev\plugins\plugin-jellyfin
    #      - C:\Develop\GitRepos\ikaros-dev\plugins\plugin-baidupan

  migration:
    enable: false
    r2dbc:
      url: r2dbc:pool:postgresql://localhost:55432/v11x
      username: ikaros
      password: ikaros

logging:
  level:
    org.springframework.data.r2dbc: INFO
    io.r2dbc: INFO
    run.ikaros.server: DEBUG
    run.ikaros.plugin: DEBUG
    run.ikaros.api: DEBUG
    org.pf4j: INFO
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql.BasicBinder: INFO
    org.springframework.r2dbc.core.DefaultDatabaseClient: DEBUG
    run.ikaros.server.cache: DEBUG

spring:
  jpa:
    show-sql: true
  r2dbc:
    url: r2dbc:pool:postgresql://localhost:5432/ikaros
    username: ikaros
    password: openpostgresql

  flyway:
    locations: classpath:db/postgresql/migration
    url: jdbc:postgresql://localhost:5432/ikaros
    user: ikaros
    password: openpostgresql
